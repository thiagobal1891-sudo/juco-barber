// ─────────────────────────────────────────────────────────────────────────────
// BarberOS — Prisma Schema
// Multi-tenant SaaS: every entity has tenantId for data isolation
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  BARBER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentGateway {
  MERCADOPAGO
  STRIPE
  CASH
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationType {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_REMINDER_2H
  APPOINTMENT_CANCELLED
  PAYMENT_COMPLETED
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT — Barbershop
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  logoUrl     String?
  phone       String?
  address     String?
  timezone    String   @default("America/Argentina/Buenos_Aires")
  isActive    Boolean  @default(true)
  plan        String   @default("free") // free | pro | enterprise
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  barbers      Barber[]
  services     Service[]
  clients      Client[]
  appointments Appointment[]
  payments     Payment[]
  notifications Notification[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER — Admin or Barber account
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole @default(BARBER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barberProfile Barber?
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])  // email unique per tenant (multi-tenant)
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// BARBER — Profile attached to a User
// ─────────────────────────────────────────────────────────────────────────────

model Barber {
  id          String  @id @default(uuid())
  tenantId    String
  userId      String  @unique
  displayName String
  bio         String?
  avatarUrl   String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability Availability[]
  appointments Appointment[]
  services     BarberService[]

  @@index([tenantId])
  @@map("barbers")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE — Catalog of services per tenant
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id              String  @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  price           Decimal @db.Decimal(10, 2)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  barbers      BarberService[]

  @@index([tenantId])
  @@map("services")
}

// ─────────────────────────────────────────────────────────────────────────────
// BARBER_SERVICE — Which services each barber offers
// ─────────────────────────────────────────────────────────────────────────────

model BarberService {
  barberId  String
  serviceId String

  barber  Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([barberId, serviceId])
  @@map("barber_services")
}

// ─────────────────────────────────────────────────────────────────────────────
// AVAILABILITY — Weekly schedule per barber
// ─────────────────────────────────────────────────────────────────────────────

model Availability {
  id        String    @id @default(uuid())
  barberId  String
  dayOfWeek DayOfWeek
  startTime String    // "HH:mm" format (e.g. "09:00")
  endTime   String    // "HH:mm" format (e.g. "18:00")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek]) // one schedule per day per barber
  @@index([barberId])
  @@map("availabilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENT — Walk-in or registered customer
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  phone     String
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([tenantId, phone]) // phone unique per tenant
  @@index([tenantId])
  @@map("clients")
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT — Core booking entity
// ─────────────────────────────────────────────────────────────────────────────

model Appointment {
  id        String            @id @default(uuid())
  tenantId  String
  barberId  String
  serviceId String
  clientId  String
  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus @default(PENDING)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barber   Barber   @relation(fields: [barberId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  client   Client   @relation(fields: [clientId], references: [id])
  payment  Payment?
  notifications Notification[]

  // ── CRITICAL: prevents double booking at DB level ─────────────────────────
  @@unique([barberId, startTime])
  @@index([tenantId])
  @@index([barberId, startTime, endTime])
  @@index([status])
  @@map("appointments")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT — One payment per appointment
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id                String         @id @default(uuid())
  tenantId          String
  appointmentId     String         @unique
  amount            Decimal        @db.Decimal(10, 2)
  currency          String         @default("ARS")
  status            PaymentStatus  @default(PENDING)
  gateway           PaymentGateway @default(CASH)
  gatewayPaymentId  String?        // external ID from MercadoPago/Stripe
  gatewayCheckoutUrl String?       // redirect URL for payment
  webhookData       Json?          // raw webhook payload for auditing
  paidAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([gatewayPaymentId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION — Audit log of sent notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id            String              @id @default(uuid())
  tenantId      String
  appointmentId String?
  channel       NotificationChannel
  type          NotificationType
  recipient     String              // email or phone
  status        NotificationStatus  @default(PENDING)
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime            @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([appointmentId])
  @@map("notifications")
}
