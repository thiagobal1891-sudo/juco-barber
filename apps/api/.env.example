# Backend environment — copy to .env and fill values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://barberos:barberos_secret@localhost:5432/barberos_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:barberos_redis_secret@localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_super_secret_access_key_min_32_chars"
JWT_REFRESH_SECRET="change_me_super_secret_refresh_key_min_32_chars"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@barberos.app"
SENDGRID_FROM_NAME="BarberOS"

# ─── MercadoPago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxx"
MERCADOPAGO_WEBHOOK_SECRET="xxxx"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# ─── WhatsApp (360dialog / Twilio) ────────────────────────────────────────────
WHATSAPP_API_URL="https://waba.360dialog.io/v1/messages"
WHATSAPP_API_TOKEN="xxxxxxxxxxxx"

# ─── Throttle ─────────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
